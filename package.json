{
  "name": "zensquid",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @zensquid/api dev",
    "dev:web": "pnpm --filter @zensquid/web dev",
    "build": "pnpm -r build",
    "smoke": "./scripts/smoke.sh",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "heartbeat:tick": "node scripts/heartbeat_tick.mjs",
    "codex": "codex"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "typescript": "^5.6.3"
  }
}
