{
  "meta": {
    "name": "ZenSquid",
    "node": "ZenPop",
    "local_first": true
  },
  "tiers": [
    { "name": "mini",  "provider": "openai", "model": "gpt-5-mini",   "role": "default assistant (cloud primary)" },
    { "name": "local", "provider": "ollama", "model": "qwen2.5:14b-instruct", "role": "baseline local fallback" },
    { "name": "qwen",  "provider": "ollama", "model": "glm-4.7-flash:latest",   "role": "fast generalist" },
    { "name": "coder", "provider": "ollama", "model": "qwen3-coder:30b",        "role": "local coding + architecture" },
    { "name": "codex", "provider": "openai", "model": "gpt-5.1-codex",          "role": "reviewer" },
    { "name": "opus",  "provider": "anthropic", "model": "claude-opus",         "role": "break-glass" }
  ],
  "budgets": {
    "monthly_usd": 20,
    "escalation_requires_reason": true
  },
  "budgets": {
  "escalation_requires_reason": true,
  "strict_local_only": true
  },
   "providers": {
    "ollama": { "base_url": "http://127.0.0.1:11434" },
    "openai": { "env_key": "OPENAI_API_KEY" },
    "anthropic": { "env_key": "ANTHROPIC_API_KEY" }
  }
}
