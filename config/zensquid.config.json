{
  "meta": {
    "name": "Squidley",
    "node": "ZenPop",
    "local_first": true,
    "safety_zone": "forge"
  },
  "tiers": [
    {
      "name": "local",
      "provider": "ollama",
      "model": "qwen2.5:14b-instruct",
      "role": "Tier 0: local-only (heartbeat + tools + safe fallback)"
    },
    {
      "name": "chat",
      "provider": "openai",
      "model": "gpt-5-mini",
      "role": "Tier 1: Chat Mode (default cloud)"
    },
    {
      "name": "chat_flash",
      "provider": "modelstudio",
      "model": "qwen-flash-us",
      "role": "Tier 1: Chat Mode (Flash compare)"
    },
    {
      "name": "plan",
      "provider": "modelstudio",
      "model": "qwen-plus-2025-12-01",
      "role": "Tier 2: Planning Mode (qwen-plus-2025-12-01)"
    },
    {
      "name": "build",
      "provider": "ollama",
      "model": "qwen3-coder:30b",
      "role": "Tier 2: Build Mode (local code generation)"
    },
    {
      "name": "big_brain",
      "provider": "modelstudio",
      "model": "qwen3-max-2026-01-23",
      "role": "Tier 3: Big Brain (qwen3-max-2026-01-23, approval required)"
    },
    {
      "name": "local_small",
      "provider": "ollama",
      "model": "llama3.2:3b",
      "role": "Tier 0: Tiny local — fast responses, simple tasks"
    },
    {
      "name": "local_phi",
      "provider": "ollama",
      "model": "phi4-mini-reasoning:3.8b",
      "role": "Tier 0: Phi4 mini — reasoning-focused small model"
    },
    {
      "name": "local_mid",
      "provider": "ollama",
      "model": "ministral-3:14b",
      "role": "Tier 1: Mistral 14b — local mid-size alternative"
    },
    {
      "name": "local_deepseek",
      "provider": "ollama",
      "model": "deepseek-coder-v2:16b",
      "role": "Tier 1: DeepSeek Coder — local code-focused model"
    },
    {
      "name": "local_gpt_oss",
      "provider": "ollama",
      "model": "gpt-oss:20b",
      "role": "Tier 2: GPT OSS 20b — local large model"
    },
    {
      "name": "local_qwen27",
      "provider": "ollama",
      "model": "qwen3.5:27b",
      "role": "Tier 2: Qwen 27b — local large, good context following"
    },
    {
      "name": "local_qwen35",
      "provider": "ollama",
      "model": "qwen3.5:35b",
      "role": "Tier 2: Qwen 35b — local largest, best local reasoning"
    },
    {
      "name": "local_nemotron",
      "provider": "ollama",
      "model": "nemotron-3-nano:latest",
      "role": "Tier 2: Nemotron — NVIDIA local model"
    },
    {
      "name": "local_glm",
      "provider": "ollama",
      "model": "glm-4.7-flash:latest",
      "role": "Tier 2: GLM Flash — fast local large model"
    }
  ],
  "budgets": {
    "monthly_usd": 40,
    "strict_local_only": false,
    "escalation_requires_reason": true,
    "big_brain_requires_approval": true,
    "daily_usd": 2.0,
    "nightly_lockout": {
      "enabled": true,
      "start": "23:00",
      "end": "04:00",
      "allow_local": true,
      "allow_cloud": false,
      "override_agents": [
        "news-briefing",
        "morning-briefing"
      ]
    }
  },
  "providers": {
    "ollama": {
      "base_url": "http://127.0.0.1:11434"
    },
    "modelstudio": {
      "env_key": "DASHSCOPE_API_KEY",
      "base_url": "https://dashscope-us.aliyuncs.com/compatible-mode"
    },
    "openai": {
      "env_key": "OPENAI_API_KEY",
      "base_url": "https://api.openai.com/v1"
    }
  }
}
