{
  "meta": {
    "name": "Squidley",
    "node": "ZenPop",
    "local_first": false,
    "safety_zone": "forge"
  },
  "tiers": [
    {
      "name": "local",
      "provider": "ollama",
      "model": "qwen2.5:14b-instruct",
      "role": "Tier 0: local-only (heartbeat + tools + safe fallback)"
    },
    {
      "name": "chat",
      "provider": "modelstudio",
      "model": "qwen3.5-plus",
      "role": "Tier 1: Chat Mode (Qwen3.5)"
    },
    {
      "name": "chat_fallback",
      "provider": "openai",
      "model": "gpt-5-mini",
      "role": "Tier 1: Fallback: OpenAI if ModelStudio fails"
    },
    {
      "name": "plan",
      "provider": "anthropic",
      "model": "claude-haiku-4-5-20251001",
      "role": "Tier 2: Planning Mode (haiku)"
    },
    {
      "name": "build",
      "provider": "ollama",
      "model": "qwen3-coder:30b",
      "role": "Tier 2: Build Mode (qwen3-coder:30b, local)"
    },
    {
      "name": "coder",
      "provider": "ollama",
      "model": "qwen3-coder:30b",
      "role": "Tier 2: Local coder (qwen-coder:30b, local, strong at code)"
    },
    {
      "name": "claude-sonnet",
      "provider": "anthropic",
      "model": "claude-sonnet-4-6",
      "role": "Tier 2: Claude Sonnet \u2014 fast, strong at code"
    },
    {
      "name": "claude-opus",
      "provider": "anthropic",
      "model": "claude-opus-4-6",
      "role": "Tier 3: Claude Opus \u2014 best reasoning, self-repair"
    },
    {
      "name": "big_brain",
      "provider": "modelstudio",
      "model": "qwen3-max-2025-09-23",
      "role": "Tier 3: Big Brain (qwen3-max-2025-09-23, approval required)"
    }
  ],
  "budgets": {
    "monthly_usd": 40,
    "strict_local_only": false,
    "escalation_requires_reason": true,
    "big_brain_requires_approval": true,
    "daily_usd": 2.0,
    "nightly_lockout": {
      "enabled": true,
      "start": "23:00",
      "end": "04:00",
      "allow_local": true,
      "allow_cloud": false,
      "override_agents": [
        "news-briefing",
        "morning-briefing"
      ]
    }
  },
  "providers": {
    "ollama": {
      "base_url": "http://127.0.0.1:11434"
    },
    "modelstudio": {
      "env_key": "DASHSCOPE_API_KEY",
      "base_url": "https://dashscope-us.aliyuncs.com/compatible-mode"
    },
    "anthropic": {
      "env_key": "ANTHROPIC_API_KEY"
    },
    "openai": {
      "env_key": "OPENAI_API_KEY",
      "base_url": "https://api.openai.com/v1"
    }
  },
  "build_pipeline": {
    "_comment": "Each stage points to a tier name from the tiers array. Change these without touching code.",
    "plan_tier": "claude-sonnet",
    "patch_tier": "plan",
    "review_tier": "claude-sonnet",
    "plan_fallback": "chat",
    "patch_fallback": "plan",
    "review_fallback": "plan"
  },
  "workspace_root": "/hogwarts/AI/squidley",
  "memory_root": "/hogwarts/AI/squidley/memory",
  "node": "ZenPop",
  "comfyui_url": "http://127.0.0.1:8188"
}